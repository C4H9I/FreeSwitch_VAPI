# Voice Bot Environment Variables
# Скопируйте этот файл в .env и заполните значения

# ===========================================
# Yandex Cloud (SpeechKit - ASR/TTS)
# ===========================================
# API ключ Yandex Cloud (получить в консоли Yandex Cloud)
YANDEX_API_KEY=your-yandex-api-key-here

# ID папки Yandex Cloud (опционально, для биллинга)
YANDEX_FOLDER_ID=your-folder-id-here

# ===========================================
# OpenAI / LLM API
# ===========================================
# API ключ OpenAI или совместимого сервиса
OPENAI_API_KEY=your-openai-api-key-here

# URL API (для OpenAI или совместимого сервиса)
# OpenAI: https://api.openai.com/v1
# Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LocalAI: http://localhost:8080/v1
# Ollama: http://localhost:11434/v1
OPENAI_API_BASE=https://api.openai.com/v1

# ===========================================
# FreeSWITCH (опционально, переопределяет YAML)
# ===========================================
# FS_ESL_HOST=127.0.0.1
# FS_ESL_PORT=8021
# FS_ESL_PASSWORD=ClueCon

# ===========================================
# Логирование
# ===========================================
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/voice-bot/bot.log

# ===========================================
# Путь к конфигурации (опционально)
# ===========================================
# VOICE_BOT_CONFIG=/path/to/agent.yaml
